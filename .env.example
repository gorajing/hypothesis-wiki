REDIS_URL=redis://localhost:6379

# Required by local Cognee graph processing. OPENAI_API_KEY is also accepted
# and will be mapped to LLM_API_KEY at runtime when LLM_API_KEY is unset.
LLM_API_KEY=

# Optional: connect to Cognee Cloud. Leave unset for local Cognee.
COGNEE_URL=
COGNEE_API_KEY=
COGNEE_DATASET=hypothesis-wiki-trusted

# Optional. Raises Semantic Scholar rate limits and stability.
SEMANTIC_SCHOLAR_API_KEY=

# Optional. Used for structured extraction and accepted by local Cognee.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
